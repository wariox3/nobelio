# Copia este archivo a .env y ajusta los valores.

# --- Django ---
DJANGO_SECRET_KEY=cambia-esta-clave
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos (PostgreSQL) ---
# Obligatorio. Formato: postgres://usuario:clave@host:puerto/nombre_bd
# El host puede ser una IP o dominio si el servicio está en otra máquina.
DATABASE_URL=postgres://usuario:clave@host:5432/nobelio

# --- DIAN ---
# Ambiente: 2 = Habilitación / Set de Pruebas, 1 = Producción
DIAN_ENVIRONMENT=2
DIAN_WSDL_HABILITACION=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc?wsdl
DIAN_WSDL_PRODUCCION=https://vpfe.dian.gov.co/WcfDianCustomerServices.svc?wsdl
DIAN_POLICY_ID=https://facturaelectronica.dian.gov.co/politicadefirma/v2/politicadefirmav2.pdf
