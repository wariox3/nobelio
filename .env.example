# Copia este archivo a .env y ajusta los valores.

# --- Django ---
# En producción usa una clave aleatoria de al menos 32 caracteres
# (con ella se firman también los tokens JWT del frontend).
DJANGO_SECRET_KEY=cambia-esta-clave
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Autenticación ---
# Orígenes del frontend (SPA en otro dominio). Separados por comas.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Activar solo si el refresh token viaja en cookie httpOnly.
CORS_ALLOW_CREDENTIALS=False
# Vida de los tokens JWT. JWT_ACCESS_MINUTOS=720 son 12 horas.
JWT_ACCESS_MINUTOS=720
JWT_REFRESH_DIAS=7

# --- Base de datos (PostgreSQL) ---
# Obligatorio. Formato: postgres://usuario:clave@host:puerto/nombre_bd
# El host puede ser una IP o dominio si el servicio está en otra máquina.
DATABASE_URL=postgres://usuario:clave@host:5432/nobelio

# --- DIAN ---
# Ambiente: 2 = Habilitación / Set de Pruebas, 1 = Producción
DIAN_ENVIRONMENT=2
DIAN_WSDL_HABILITACION=https://vpfe-hab.dian.gov.co/WcfDianCustomerServices.svc?wsdl
DIAN_WSDL_PRODUCCION=https://vpfe.dian.gov.co/WcfDianCustomerServices.svc?wsdl
DIAN_POLICY_ID=https://facturaelectronica.dian.gov.co/politicadefirma/v2/politicadefirmav2.pdf

# --- Almacenamiento Backblaze B2 (S3-compatible) ---
# OBLIGATORIO para subir certificados .p12: el material criptográfico se
# guarda siempre en B2 (dev y prod), nunca en disco local. Si faltan estas
# variables, la API rechaza la carga de certificados.
B2_BUCKET=
B2_ENDPOINT_URL=  # p.ej. https://s3.us-west-004.backblazeb2.com
B2_REGION=        # p.ej. us-west-004
B2_KEY_ID=        # keyID (access key)
B2_APP_KEY=       # applicationKey (secret key)
